<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>ckpg report</title>
  <style>
    :root {
      color-scheme: light;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #f6f8fb;
      color: #18202f;
    }
    body {
      margin: 0;
      padding: 32px;
    }
    main {
      max-width: 1180px;
      margin: 0 auto;
    }
    h1, h2 {
      margin: 0 0 16px;
      letter-spacing: 0;
    }
    section {
      margin: 0 0 28px;
    }
    .summary {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 12px;
    }
    .metric {
      background: #ffffff;
      border: 1px solid #d9e1ee;
      border-radius: 8px;
      padding: 14px;
    }
    .metric strong {
      display: block;
      font-size: 28px;
      line-height: 1.1;
    }
    .metric span {
      display: block;
      color: #4f5f73;
      margin-top: 4px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      background: #ffffff;
      border: 1px solid #d9e1ee;
      border-radius: 8px;
      overflow: hidden;
    }
    th, td {
      border-bottom: 1px solid #e6ebf3;
      padding: 10px 12px;
      text-align: left;
      vertical-align: top;
      font-size: 14px;
    }
    th {
      color: #34445a;
      background: #edf2f8;
      font-weight: 650;
    }
    tr:last-child td {
      border-bottom: 0;
    }
    .status {
      font-weight: 650;
    }
    .error {
      color: #b42318;
    }
    .warning {
      color: #9a6700;
    }
    .muted {
      color: #5d6b7c;
    }
    code {
      word-break: break-all;
    }
  </style>
</head>
<body>
  <main>
    <section>
      <h1>ckpg report</h1>
      <p class="muted">
        Before: <code>{{ before_name }}</code><br>
        After: <code>{{ after_name }}</code><br>
        Generated: {{ report.generated_at.isoformat() }}
      </p>
    </section>

    <section class="summary">
      <div class="metric"><strong>{{ report.diff.summary.added }}</strong><span>Added</span></div>
      <div class="metric"><strong>{{ report.diff.summary.removed }}</strong><span>Removed</span></div>
      <div class="metric"><strong>{{ report.diff.summary.changed }}</strong><span>Changed</span></div>
      <div class="metric"><strong>{{ report.audit.findings | length }}</strong><span>Audit findings</span></div>
    </section>

    <section>
      <h2>Top tensor diffs</h2>
      <table>
        <thead>
          <tr>
            <th>Tensor</th>
            <th>Status</th>
            <th>Changes</th>
            <th>Score</th>
            <th>Cosine distance</th>
          </tr>
        </thead>
        <tbody>
          {% for diff in top_diffs %}
          <tr>
            <td><code>{{ diff.name }}</code></td>
            <td class="status">{{ diff.status }}</td>
            <td>{{ diff.changes | join(", ") if diff.changes else "none" }}</td>
            <td>{{ "%.4f"|format(diff.score) }}</td>
            <td>{{ "%.6f"|format(diff.cosine_distance) if diff.cosine_distance is not none else "n/a" }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </section>

    <section>
      <h2>Audit findings</h2>
      <table>
        <thead>
          <tr>
            <th>Severity</th>
            <th>Category</th>
            <th>Tensor</th>
            <th>Message</th>
            <th>Value</th>
          </tr>
        </thead>
        <tbody>
          {% for finding in report.audit.findings %}
          <tr>
            <td class="{{ finding.severity }}">{{ finding.severity }}</td>
            <td>{{ finding.category }}</td>
            <td><code>{{ finding.tensor or "checkpoint" }}</code></td>
            <td>{{ finding.message }}</td>
            <td>{{ finding.value if finding.value is not none else "n/a" }}</td>
          </tr>
          {% else %}
          <tr>
            <td colspan="5">No audit findings.</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </section>
  </main>
</body>
</html>
